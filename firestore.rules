rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      // Use get() to fetch the role from the user's profile document. 
      // Defaults to null if the document doesn't exist.
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isArtisan() {
      return isAuthenticated() && getRole() == 'artisan';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if true; // Public read
      allow create: if true; // Allow anon insert for seeding / signups
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true; // Public read
      allow create: if true; // Allow anon insert for seeding
      allow update, delete: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true; // Public read
      allow create: if true; // Allow anon insert for seeding
      // Artisans can update/delete their own products
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.artisan_id == request.auth.uid);
    }

    // Artisans
    match /artisans/{artisanId} {
      allow read: if true; // Public read
      allow create: if true; // Allow anon insert for seeding
      allow update, delete: if isAdmin() || isOwner(artisanId);
    }

    // Artisan Stories
    match /artisan_stories/{storyId} {
      allow read: if true; // Public read
      allow create: if true; // Allow anon insert for seeding
      allow update, delete: if isAdmin();
    }

    // Wholesale Applications
    match /wholesale_applications/{appId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Commissions
    match /commissions/{commissionId} {
      allow read, write: if isAdmin();
    }

    // Craftpedia Articles
    match /craftpedia_articles/{articleId} {
      allow read: if resource.data.status == 'published' || isAdmin() || (isAuthenticated() && resource.data.author_id == request.auth.uid);
      allow create, update: if isAdmin() || isArtisan();
      allow delete: if isAdmin();
    }

    // Craftpedia Edits
    match /craftpedia_edits/{editId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.editor_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Artisan Live Feeds
    match /artisan_feeds/{feedId} {
      allow read: if resource.data.status == 'active' || isAdmin() || (isAuthenticated() && resource.data.artisan_id == request.auth.uid);
      allow create, update, delete: if isAdmin() || (isAuthenticated() && resource.data.artisan_id == request.auth.uid);
    }

    // Feed Engagement
    match /feed_engagement/{engId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Configs (Logistics & Currency)
    match /logistics_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /currency_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAdmin() || isArtisan() || (isAuthenticated() && resource.data.customer_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.customer_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Order Items
    match /order_items/{itemId} {
      allow read: if true; // Guests can view order items by ID
      allow write: if isAdmin(); // Only admins can modify directly, or handled securely
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Default rule: Secure by default.
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
